rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdminUser() {
      return request.auth != null
        && (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
          || request.auth.token.email.lower() == 'ironladytech@gmail.com'
        );
    }

    match /resources/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdminUser();
    }

    match /courses/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdminUser();
    }

    match /events/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdminUser();
    }
  }
}
