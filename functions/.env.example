# Zoho OAuth — connects LMS server to Zoho API (NOT learner login credentials)
ZOHO_CLIENT_ID=1000.KF6VIEYOCCV4YGO4A9KEWMDNXHZ0IR
ZOHO_CLIENT_SECRET=77e6b3a21b327b64fe08bd509edb43958c9f7e0af9
ZOHO_REFRESH_TOKEN=1000.0e4e23342b95a310c1b5dc4f1f4301bc.19ccab019de29c24d7a0104f4101af0d
ZOHO_API_DOMAIN=https://www.zohoapis.in
ZOHO_CRM_MODULE=Leads
ZOHO_IL_USERS_MODULE=IL_Users
# If Email/Username search fails, also tries IL Registration → IL_User lookup
ZOHO_IL_REGISTRATION_MODULE=IL_Registration
# Override only if your Zoho field API names differ:
# ZOHO_IL_USERS_EMAIL_FIELD=Email
# ZOHO_IL_USERS_USERNAME_FIELD=Username
# ZOHO_IL_REG_EMAIL_FIELD=Email
# ZOHO_IL_REG_ILUSER_LOOKUP_FIELD=IL_User

# OAuth — custom modules (IL Users) are NOT valid as ZohoCRM.modules.IL_Users.ALL in API Console.
# Use modules.ALL (covers Leads + all custom modules + Notes) + coql.READ:
# ZohoCRM.modules.ALL,ZohoCRM.coql.READ
# To find exact custom module API names: CRM → Setup → Developer Space → APIs → API Names

# Learner credentials — Lead custom fields (create in Setup → Leads → Fields):
# LMS_Password, LMS_Password_Updated_At, LMS_Credential_Status
# New LMS writes IL_Users.LMS_Password only. Legacy IL_Users.Password (old Moodle) is read-only unless:
# ZOHO_SYNC_IL_USERS_LEGACY_PASSWORD=true
# ZOHO_FIELD_USERNAME=LMS_Username
# ZOHO_FIELD_PASSWORD=LMS_Password
# ZOHO_FIELD_PAYMENT_STATUS=Payment_Status
# ZOHO_FIELD_LEAD_STATUS=Lead_Status
# Optional — secure Zoho automation webhook (header: x-zoho-webhook-secret)
ZOHO_WEBHOOK_SECRET=
