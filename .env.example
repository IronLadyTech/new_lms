# Firebase — https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push (FCM) — Firebase Console → Project settings → Cloud Messaging →
# Web Push certificates → "Key pair". Required for push notifications; if unset,
# push is silently disabled. Set this on every deploy target (e.g. Vercel) too.
VITE_FIREBASE_VAPID_KEY=

# Zoho CRM — put credentials in functions/.env (copy from functions/.env.example)
# NOT in this root .env file
